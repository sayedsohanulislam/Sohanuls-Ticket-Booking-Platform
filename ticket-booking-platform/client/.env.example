# ====== Client Environment Variables ======
# Copy this file to .env and fill in real values.
# Vite exposes only vars prefixed with VITE_ to the client.

# API base URL (the Express server)
VITE_API_URL=http://localhost:5000/api

# Stripe publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_real_key

# imgbb API key (used directly from the client for ticket image uploads)
VITE_IMGBB_API_KEY=your_imgbb_api_key

# Google OAuth Client ID (for "Continue with Google" button on Login/Register)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
